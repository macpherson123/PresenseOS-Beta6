{
  "expo": {
    "name": "PresenceOS",
    "slug": "presenceos-pilot",
    "version": "36",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "presenceos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050A10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.presenceos.lite",
      "infoPlist": {
        "NSCameraUsageDescription": "PresenceOS uses your camera for photos and video calls.",
        "NSMicrophoneUsageDescription": "PresenceOS uses your microphone for calls.",
        "NSLocationWhenInUseUsageDescription": "PresenceOS uses location for the weather widget only.",
        "NSPhotoLibraryUsageDescription": "PresenceOS accesses photos for wallpaper selection.",
        "NSContactsUsageDescription": "PresenceOS reads contacts for calling and messaging."
      }
    },
    "android": {
	"versionCode": 37,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050A10"
      },
      "package": "com.android.launcher3",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.EXPAND_STATUS_BAR",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.DISABLE_KEYGUARD",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.FLASHLIGHT",
        "android.permission.NFC",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_CALL_LOG",
        "android.permission.WRITE_CALL_LOG",
        "android.permission.CALL_PHONE",
        "android.permission.PROCESS_OUTGOING_CALLS",
        "android.permission.ANSWER_PHONE_CALLS",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.READ_PHONE_STATE",
        "android.permission.SEND_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.WRITE_SMS",
        "android.permission.RECEIVE_MMS",
        "android.permission.RECEIVE_WAP_PUSH",
        "android.permission.SEND_RESPOND_VIA_MESSAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MANAGE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ]
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#00000000"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "PresenceOS uses your camera for photos and video calls.",
          "microphonePermission": "PresenceOS uses your microphone for calls.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "PresenceOS accesses your media library for music and photos.",
          "savePhotosPermission": "PresenceOS saves photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "PresenceOS uses location for the weather widget only while the app is open."
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "PresenceOS uses NFC to securely pair with other devices.",
          "selectIdentifiers": [],
          "systemCodes": []
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3c01794d-1075-4fcf-a474-ad2b51d492f9"
      }
    },
    "owner": "macpherson123",
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-qrcode-svg",
          "react-native-nfc-manager",
          "react-native-webrtc"
        ]
      }
    }
  }
}